{
  "dashboard": {
    "title": "SecureStack Security Operations Dashboard",
    "description": "Real-time security metrics for the SecureStack platform",
    "tags": ["security", "devsecops"],
    "panels": [
      {
        "id": 1,
        "title": "HTTP requests per second",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [{ "expr": "rate(http_requests_total[1m])", "legendFormat": "{{method}} {{path}} {{status}}" }],
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
      },
      {
        "id": 2,
        "title": "API response time (p95)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [{ "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[1m]))", "legendFormat": "p95 latency" }],
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
      },
      {
        "id": 3,
        "title": "Failed login attempts",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [{ "expr": "rate(login_attempts_total{status=\"failed\"}[1m])", "legendFormat": "Failed logins/sec" }],
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
      },
      {
        "id": 4,
        "title": "Successful logins",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [{ "expr": "rate(login_attempts_total{status=\"success\"}[1m])", "legendFormat": "Successful logins/sec" }],
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
      },
      {
        "id": 5,
        "title": "Total HTTP requests",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
        "targets": [{ "expr": "sum(http_requests_total)", "legendFormat": "Total requests" }],
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
      },
      {
        "id": 6,
        "title": "Total failed logins",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
        "targets": [{ "expr": "sum(login_attempts_total{status=\"failed\"})", "legendFormat": "Failed logins" }],
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 5, "color": "yellow" }, { "value": 20, "color": "red" }] } } }
      },
      {
        "id": 7,
        "title": "API memory usage (MB)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
        "targets": [{ "expr": "process_resident_memory_bytes / 1024 / 1024", "legendFormat": "Memory (MB)" }],
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
      },
      {
        "id": 8,
        "title": "API CPU usage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
        "targets": [{ "expr": "rate(process_cpu_seconds_total[1m])", "legendFormat": "CPU seconds/sec" }],
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
      },
      {
        "id": 9,
        "title": "Active file descriptors",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
        "targets": [{ "expr": "process_open_fds", "legendFormat": "Open file descriptors" }],
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
      },
      {
        "id": 10,
        "title": "Event loop lag (seconds)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
        "targets": [{ "expr": "nodejs_eventloop_lag_seconds", "legendFormat": "Event loop lag" }],
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
      }
    ]
  }
}
